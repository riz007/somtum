{
  "name": "somtum",
  "version": "0.1.0",
  "description": "Local-first memory and prompt-cache layer for Claude Code",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Rizwanul Islam Rudra",
    "url": "https://github.com/riz007"
  },
  "homepage": "https://riz007.github.io/somtum/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/riz007/somtum.git"
  },
  "bugs": {
    "url": "https://github.com/riz007/somtum/issues"
  },
  "keywords": [
    "claude-code",
    "memory",
    "prompt-cache",
    "sqlite",
    "cli",
    "embeddings",
    "artifical-intelligence",
    "local-first",
    "anthropic",
    "agentic-ai",
    "rag",
    "retrieval-augmented-generation",
    "claude-code-plugin",
    "claude-agents",
    "claude-skills",
    "memory-engine",
    "agentic-coding",
    "long-term-memory",
    "context-management",
    "knowledge-graph",
    "semantic-search",
    "vector-database",
    "open-source"
  ],
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.0",
  "bin": {
    "somtum": "./dist/cli/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepublishOnly": "pnpm build",
    "build": "tsc -p tsconfig.build.json && pnpm run build:copy-migrations",
    "build:copy-migrations": "node -e \"import('node:fs').then(({mkdirSync,cpSync})=>{mkdirSync('dist/db/migrations',{recursive:true});cpSync('src/db/migrations','dist/db/migrations',{recursive:true});})\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:golden": "vitest run test/golden",
    "test:bench": "vitest bench",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "fmt": "prettier --write \"src/**/*.{ts,json,md}\" \"*.{md,json}\"",
    "dev:hook:post_session": "tsx src/hooks/post_session.ts",
    "release": "changeset publish"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^11.5.0",
    "commander": "^12.1.0",
    "gpt-tokenizer": "^2.5.1",
    "ulid": "^2.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.10",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
